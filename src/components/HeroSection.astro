---
interface Props {
  title: string;
  subtitle?: string;
  compact?: boolean;
  ctaText?: string;
  ctaHref?: string;
}

const { title, subtitle, compact = false, ctaText, ctaHref } = Astro.props;
---

<section
  class:list={[
    'relative flex items-center justify-center text-white',
    compact ? 'py-12 md:py-20' : 'py-20 md:py-32',
  ]}
>
  <!-- Background with gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-light to-primary" aria-hidden="true">
    <!-- Subtle pattern overlay -->
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 50%, rgba(22, 163, 74, 0.3) 0%, transparent 50%), radial-gradient(circle at 75% 50%, rgba(245, 158, 11, 0.2) 0%, transparent 50%);" />

    <!-- Stilisierte Fußballfeld-Linien (sehr dezent) -->
    <svg
      class="absolute inset-0 w-full h-full opacity-[0.07]"
      viewBox="0 0 1200 600"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <g fill="none" stroke="white" stroke-width="2">
        <!-- Mittelkreis -->
        <circle cx="600" cy="300" r="90" />
        <!-- Mittellinie -->
        <line x1="600" y1="0" x2="600" y2="600" />
        <!-- Strafraum links -->
        <rect x="0" y="180" width="160" height="240" />
        <rect x="0" y="240" width="60" height="120" />
        <!-- Strafraum rechts -->
        <rect x="1040" y="180" width="160" height="240" />
        <rect x="1140" y="240" width="60" height="120" />
      </g>
    </svg>

    <!-- Dezente Tor-Silhouette rechts -->
    <svg
      class="absolute right-0 top-1/2 -translate-y-1/2 h-3/4 w-auto opacity-[0.09] hidden md:block"
      viewBox="0 0 240 180"
      aria-hidden="true"
    >
      <g fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="square">
        <path d="M 30 160 L 30 30 L 210 30 L 210 160" />
        <g stroke-width="1" opacity="0.5">
          <line x1="48" y1="38" x2="48" y2="160" />
          <line x1="72" y1="38" x2="72" y2="160" />
          <line x1="96" y1="38" x2="96" y2="160" />
          <line x1="120" y1="38" x2="120" y2="160" />
          <line x1="144" y1="38" x2="144" y2="160" />
          <line x1="168" y1="38" x2="168" y2="160" />
          <line x1="192" y1="38" x2="192" y2="160" />
          <line x1="30" y1="55" x2="210" y2="55" />
          <line x1="30" y1="80" x2="210" y2="80" />
          <line x1="30" y1="110" x2="210" y2="110" />
          <line x1="30" y1="140" x2="210" y2="140" />
        </g>
      </g>
    </svg>
  </div>

  <div class="relative container mx-auto text-center max-w-4xl">
    <h1 class="font-heading font-extrabold text-white mb-4 md:mb-6">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl mx-auto leading-relaxed">
        {subtitle}
      </p>
    )}
    {ctaText && ctaHref && (
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-bold text-base px-8 py-3.5 rounded-lg transition-colors no-underline shadow-lg shadow-accent/20"
      >
        {ctaText}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    )}
  </div>
</section>
