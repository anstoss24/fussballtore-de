---
import { addUtm } from '../utils/utm';

interface Props {
  name: string;
  url: string;
  imageUrl: string;
  features: string[];
  category?: string;
  campaign: string;
}

const { name, url, imageUrl, features, category, campaign } = Astro.props;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  image: imageUrl,
  url,
  brand: {
    '@type': 'Brand',
    name: 'anstoss24',
  },
  offers: {
    '@type': 'Offer',
    url,
    availability: 'https://schema.org/InStock',
    seller: {
      '@type': 'Organization',
      name: 'anstoss24.de',
    },
  },
};
---

<article class="group bg-white rounded-xl border border-neutral-200 overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
  <!-- Product Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  <!-- Image -->
  <div class="relative aspect-[4/3] overflow-hidden bg-neutral-50">
    <img
      src={imageUrl}
      alt={name}
      loading="lazy"
      width="400"
      height="300"
      class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
    />
  </div>

  <!-- Content -->
  <div class="p-5">
    {category && (
      <span class="inline-block text-xs font-medium text-accent uppercase tracking-wider mb-2">
        {category}
      </span>
    )}
    <h3 class="font-heading text-base font-bold text-primary leading-snug mb-3 line-clamp-2">
      {name}
    </h3>

    <!-- Feature Pills -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {features.slice(0, 4).map((feature) => (
        <span class="inline-block text-xs bg-neutral-50 text-neutral-500 border border-neutral-200 px-2 py-0.5 rounded-md">
          {feature}
        </span>
      ))}
    </div>

    <!-- CTA -->
    <a
      href={addUtm(url, campaign, 'product-card')}
      target="_blank"
      rel="noopener"
      class="block w-full text-center bg-accent hover:bg-accent-dark text-white font-medium text-sm py-2.5 px-4 rounded-lg transition-colors no-underline"
    >
      Preis jetzt prüfen &rarr;
    </a>
  </div>
</article>
