---
import { addUtm } from '../utils/utm';
import pricesData from '../data/prices.json';

interface Props {
  name: string;
  url: string;
  imageUrl: string;
  features: string[];
  category?: string;
  campaign: string;
}

const { name, url, imageUrl, features, category, campaign } = Astro.props;

const priceInfo = (pricesData as Record<string, any>)[url];
const price = priceInfo?.price;
const uvp = priceInfo?.uvp;
const currency = priceInfo?.currency || 'EUR';
const priceValidUntil = priceInfo?.priceValidUntil;
const discount = uvp && price ? Math.round((1 - price / uvp) * 100) : null;

const formatPrice = (p: number) =>
  new Intl.NumberFormat('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(p);

const productSchema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  image: imageUrl,
  url,
  brand: {
    '@type': 'Brand',
    name: 'anstoss24',
  },
};

if (price) {
  productSchema.offers = {
    '@type': 'Offer',
    url,
    price,
    priceCurrency: currency,
    priceValidUntil,
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    seller: {
      '@type': 'Organization',
      name: 'anstoss24.de',
    },
    ...(uvp && {
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        priceType: 'https://schema.org/StrikethroughPrice',
        price: uvp,
        priceCurrency: currency,
      },
    }),
  };
}
---

<article class="group bg-white rounded-xl border border-neutral-200 overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
  <!-- Product Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  <!-- Image -->
  <div class="relative aspect-[4/3] overflow-hidden bg-neutral-50">
    <img
      src={imageUrl}
      alt={name}
      loading="lazy"
      width="400"
      height="300"
      class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
    />
  </div>

  <!-- Content -->
  <div class="p-5">
    {category && (
      <span class="inline-block text-xs font-medium text-accent uppercase tracking-wider mb-2">
        {category}
      </span>
    )}
    <h3 class="font-heading text-base font-bold text-primary leading-snug mb-3 line-clamp-2">
      {name}
    </h3>

    <!-- Feature Pills -->
    <div class="flex flex-wrap gap-1.5 mb-3">
      {features.slice(0, 4).map((feature) => (
        <span class="inline-block text-xs bg-neutral-50 text-neutral-500 border border-neutral-200 px-2 py-0.5 rounded-md">
          {feature}
        </span>
      ))}
    </div>

    <!-- Price -->
    {price && (
      <div class="mb-3">
        <span class="text-lg font-bold text-primary">{formatPrice(price)} €</span>
        {uvp && (
          <span class="ml-2 text-sm text-neutral-400 line-through">{formatPrice(uvp)} €</span>
        )}
        {discount && discount >= 5 && (
          <span class="ml-1.5 text-xs font-semibold text-green-700 bg-green-50 px-1.5 py-0.5 rounded">
            -{discount}%
          </span>
        )}
      </div>
    )}

    <!-- CTA -->
    <a
      href={addUtm(url, campaign, 'product-card')}
      target="_blank"
      rel="noopener"
      class="block w-full text-center bg-accent hover:bg-accent-dark text-white font-medium text-sm py-2.5 px-4 rounded-lg transition-colors no-underline"
    >
      Preis jetzt prüfen &rarr;
    </a>
  </div>
</article>
