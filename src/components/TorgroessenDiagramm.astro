---
// Maßstabsgetreue Darstellung der gängigen Fußballtor-Größen.
// Skalierung: 1 m = 60 px

const goals = [
  { label: 'Großfeld', dims: '7,32 × 2,44 m', widthM: 7.32, heightM: 2.44, color: '#16a34a', context: 'Herren / Frauen / C-A-Jugend' },
  { label: 'Jugend', dims: '5,00 × 2,00 m', widthM: 5.0, heightM: 2.0, color: '#15803d', context: 'D-Jugend (U12/U13)' },
  { label: 'Kleinfeld', dims: '3,00 × 2,00 m', widthM: 3.0, heightM: 2.0, color: '#22c55e', context: 'F-Jugend, Bolzplatz' },
  { label: 'Mini', dims: '1,20 × 0,80 m', widthM: 1.2, heightM: 0.8, color: '#86efac', context: 'Bambini / Funino / Garten' },
];

const scale = 50;        // px pro Meter
const maxWidthPx = 7.32 * scale;
const baselineY = 2.44 * scale + 30;  // Boden
const viewWidth = maxWidthPx + 200;   // Platz für Labels rechts
const viewHeight = baselineY + 80;
const startX = 30;
---

<figure class="my-10 bg-neutral-50 rounded-2xl p-6 md:p-10 overflow-x-auto">
  <figcaption class="font-heading text-lg font-bold text-primary mb-6">
    Fußballtor-Größen im Maßstab 1:50
  </figcaption>

  <svg
    role="img"
    aria-label="Maßstabsgetreuer Vergleich aller Fußballtor-Größen"
    width={viewWidth}
    height={viewHeight}
    viewBox={`0 0 ${viewWidth} ${viewHeight}`}
    class="max-w-full h-auto"
  >
    <!-- Bodenlinie -->
    <line
      x1="0"
      y1={baselineY}
      x2={viewWidth}
      y2={baselineY}
      stroke="#94a3b8"
      stroke-width="1"
      stroke-dasharray="4 4"
    />

    <!-- Person als Größenreferenz: 1,75 m -->
    {(() => {
      const personHeight = 1.75 * scale;
      const personX = startX - 18;
      return (
        <g transform={`translate(${personX}, ${baselineY - personHeight})`} opacity="0.6">
          <circle cx="6" cy="8" r="6" fill="#64748b" />
          <rect x="0" y="14" width="12" height={personHeight - 14} fill="#64748b" rx="2" />
          <text x="-32" y={personHeight + 4} font-size="9" fill="#64748b" font-family="sans-serif">1,75 m</text>
        </g>
      );
    })()}

    <!-- Tore -->
    {goals.map((g, idx) => {
      const w = g.widthM * scale;
      const h = g.heightM * scale;
      const x = startX + (maxWidthPx - w) / 2;  // zentriert
      const y = baselineY - h;
      const offsetY = idx === 0 ? 0 : 0;
      const strokeWidth = 3;

      return (
        <g>
          {/* Tor-Rahmen */}
          <rect
            x={x}
            y={y}
            width={w}
            height={h}
            fill="none"
            stroke={g.color}
            stroke-width={strokeWidth}
            stroke-linejoin="miter"
          />
          {/* Label rechts vom Tor */}
          <text
            x={x + w + 16}
            y={y + h / 2 - 2}
            font-size="13"
            font-weight="700"
            fill={g.color}
            font-family="sans-serif"
          >
            {g.label}
          </text>
          <text
            x={x + w + 16}
            y={y + h / 2 + 14}
            font-size="11"
            fill="#64748b"
            font-family="sans-serif"
          >
            {g.dims}
          </text>
        </g>
      );
    })}

    <!-- Bodenbeschriftung -->
    <text
      x={startX}
      y={baselineY + 20}
      font-size="10"
      fill="#94a3b8"
      font-family="sans-serif"
    >
      Bodenlinie
    </text>
  </svg>

  <div class="mt-6 text-sm text-neutral-500 leading-relaxed">
    Alle Tore vom selben Bodenpunkt aus. Die graue Figur links zeigt die Größe eines Menschen (1,75 m) als Referenz. Maßstab 1 Meter = 50 Pixel.
  </div>
</figure>
