---
const navItems = [
  { label: 'Kaufberatung', href: '/kaufberatung' },
  { label: 'Größen', href: '/groessen' },
  { label: 'Material', href: '/material-vergleich' },
  { label: 'Garten', href: '/garten' },
  { label: 'Kinder', href: '/kinder' },
  { label: 'Verein', href: '/verein' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-neutral-200/80">
  <div class="container mx-auto flex items-center justify-between h-16 md:h-18">
    <!-- Logo -->
    <a href="/" class="font-heading font-extrabold text-xl md:text-2xl text-primary hover:text-primary no-underline">
      fussballtore.de
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-3 py-2 text-sm font-medium rounded-lg transition-colors no-underline',
            currentPath === item.href
              ? 'text-accent bg-accent/5'
              : 'text-primary/70 hover:text-primary hover:bg-neutral-50',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile Menu Toggle -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 -mr-2" aria-label="Menü öffnen">
      <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </div>

  <!-- Mobile Menu (CSS-only with checkbox hack) -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />
  <nav
    class="md:hidden peer-checked:block hidden border-t border-neutral-200 bg-white"
    aria-label="Mobile Navigation"
  >
    <div class="container mx-auto py-3 flex flex-col gap-1">
      <a
        href="/"
        class:list={[
          'px-4 py-2.5 rounded-lg text-base font-medium transition-colors no-underline',
          currentPath === '/'
            ? 'text-accent bg-accent/5'
            : 'text-primary/70 hover:text-primary hover:bg-neutral-50',
        ]}
      >
        Startseite
      </a>
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-4 py-2.5 rounded-lg text-base font-medium transition-colors no-underline',
            currentPath === item.href
              ? 'text-accent bg-accent/5'
              : 'text-primary/70 hover:text-primary hover:bg-neutral-50',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>
