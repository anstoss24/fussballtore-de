---
interface Props {
  name: string;
  subtitle: string;
  href: string;
  icon?: string;
}

const { name, subtitle, href } = Astro.props;
---

<a
  href={href}
  class="group block bg-white border border-neutral-200 rounded-xl p-6 hover:border-accent/30 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 no-underline"
>
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center">
      <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016A3.001 3.001 0 0021 9.349m-18 0V7.875C3 6.839 3.839 6 4.875 6h14.25C20.161 6 21 6.839 21 7.875v1.474" />
      </svg>
    </div>
    <div>
      <h3 class="font-heading text-lg font-bold text-primary mb-1 group-hover:text-accent transition-colors">
        {name}
      </h3>
      <p class="text-sm text-neutral-500 leading-relaxed">
        {subtitle}
      </p>
    </div>
  </div>
</a>
