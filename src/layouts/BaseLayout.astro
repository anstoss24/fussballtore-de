---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.jpg',
  schema,
  noindex = false,
} = Astro.props;

const siteName = 'fussballtore.de';
const siteUrl = 'https://fussballtore.de';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="evXzaTTXF-aXoB3g1srMntHxTYjpPOYYyZ9kGxMHskc" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:locale" content="de_DE" />

    <!-- Font Preloads -->
    <link rel="preload" href="/fonts/PlusJakartaSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org JSON-LD -->
    {schema && (
      Array.isArray(schema)
        ? schema.map((s) => (
            <script type="application/ld+json" set:html={JSON.stringify(s)} />
          ))
        : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- TEMPORARY: Client-side password protection – remove when no longer needed -->
    <div id="pw-gate" style="position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:#fff">
      <form id="pw-form" style="text-align:center;font-family:system-ui,sans-serif">
        <p style="font-size:1.25rem;margin-bottom:1rem;color:#1a1a1a">Passwortgeschützter Bereich</p>
        <input id="pw-input" type="password" placeholder="Passwort eingeben" autocomplete="off"
          style="padding:0.5rem 1rem;border:2px solid #d1d5db;border-radius:0.5rem;font-size:1rem;outline:none" />
        <button type="submit"
          style="margin-left:0.5rem;padding:0.5rem 1.25rem;background:#16a34a;color:#fff;border:none;border-radius:0.5rem;font-size:1rem;cursor:pointer">OK</button>
        <p id="pw-error" style="color:#dc2626;margin-top:0.75rem;display:none">Falsches Passwort</p>
      </form>
    </div>
    <script is:inline>
      (function(){
        var PW='fussball2026';
        if(sessionStorage.getItem('pw-ok')===PW){document.getElementById('pw-gate').remove();return}
        document.getElementById('pw-form').addEventListener('submit',function(e){
          e.preventDefault();
          if(document.getElementById('pw-input').value===PW){
            sessionStorage.setItem('pw-ok',PW);
            document.getElementById('pw-gate').remove();
          }else{
            document.getElementById('pw-error').style.display='block';
          }
        });
      })();
    </script>

    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
