---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Seite nicht gefunden';
const description = 'Die gesuchte Seite existiert nicht. Zurück zur Startseite oder zu unseren Ratgebern.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="container mx-auto px-4 py-24 text-center max-w-2xl">
    <p class="text-6xl font-bold text-neutral-200 mb-4">404</p>
    <h1 class="font-heading text-2xl md:text-3xl font-bold text-primary mb-4">Seite nicht gefunden</h1>
    <p class="text-neutral-500 mb-10">
      Die Seite, die du suchst, existiert leider nicht oder wurde verschoben.
    </p>

    <nav class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="inline-block bg-accent hover:bg-accent-dark text-white font-medium text-sm py-3 px-6 rounded-lg transition-colors no-underline">
        Zur Startseite
      </a>
      <a href="/kaufberatung" class="inline-block border border-neutral-300 hover:border-neutral-400 text-primary font-medium text-sm py-3 px-6 rounded-lg transition-colors no-underline">
        Kaufberatung
      </a>
      <a href="/groessen" class="inline-block border border-neutral-300 hover:border-neutral-400 text-primary font-medium text-sm py-3 px-6 rounded-lg transition-colors no-underline">
        Größen-Übersicht
      </a>
    </nav>
  </section>
</BaseLayout>
