---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { addUtm } from '../utils/utm';

const title = 'Über fussballtore.de – Wer dahinter steht';
const description =
  'fussballtore.de ist das Ratgeber-Portal eines Vereinsbedarf-Fachhändlers mit 14 Jahren Erfahrung. So entstehen unsere Inhalte und das steckt dahinter.';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: title,
    description,
    inLanguage: 'de-DE',
    url: 'https://fussballtore.de/ueber-uns/',
    mainEntity: {
      '@type': 'Person',
      name: 'Matthias Frank',
      description: 'Tätig im Vereinsbedarf-Fachhandel mit Schwerpunkt Fußballtore',
      url: 'https://fussballtore.de/ueber-uns/',
    },
    publisher: {
      '@type': 'Organization',
      name: 'fussballtore.de',
      url: 'https://fussballtore.de',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://fussballtore.de/' },
      { '@type': 'ListItem', position: 2, name: 'Über uns', item: 'https://fussballtore.de/ueber-uns/' },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schema} ogImage="/og-ueber-uns.jpg">
  <HeroSection
    title="Über fussballtore.de"
    subtitle="14 Jahre Praxis im Vereinsbedarf — und was das für unsere Ratgeber bedeutet"
    compact
  />
  <Breadcrumb items={[{ label: 'Start', href: '/' }, { label: 'Über uns' }]} />

  <article class="container mx-auto max-w-3xl py-12 md:py-16">

    <!-- Einleitung -->
    <p class="text-lg md:text-xl text-neutral-700 leading-relaxed mb-6">
      fussballtore.de ist das Ratgeber-Portal eines Vereinsbedarf-Fachhändlers,
      der seit <strong>14 Jahren</strong> Vereine, Schulen und Kommunen mit
      Sportausstattung versorgt. Hinter den Inhalten steht keine einzelne Person,
      sondern die gebündelte Erfahrung aus vielen Jahren Beratung im Fachhandel.
    </p>

    <!-- 14 Jahre Praxis -->
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mt-12 mb-4">
      14 Jahre Praxis im Vereinsbedarf
    </h2>
    <p class="text-neutral-600 leading-relaxed mb-4">
      Seit 14 Jahren beliefern wir Vereine, Schulen und Kommunen mit Fußballtoren,
      Tornetzen und Trainingsausstattung. In dieser Zeit haben wir gesehen:
    </p>
    <ul class="space-y-2 text-neutral-600 leading-relaxed mb-6 list-disc list-inside ml-2">
      <li>welche Tore lange halten und welche im Alltag schnell an ihre Grenzen kommen,</li>
      <li>wie sich Materialien unter Witterung tatsächlich verhalten,</li>
      <li>welche Anforderungen Vereine immer wieder unterschätzen,</li>
      <li>welche Beratungsfehler beim Erstkauf gehäuft passieren.</li>
    </ul>
    <p class="text-neutral-600 leading-relaxed mb-4">
      Dieses Wissen aus der täglichen Praxis fließt direkt in die Ratgeber auf
      fussballtore.de ein.
    </p>

    <!-- Matthias -->
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mt-12 mb-4">
      Verfasst von Matthias Frank
    </h2>
    <p class="text-neutral-600 leading-relaxed mb-4">
      Matthias ist im Vereinsbedarf-Fachhandel tätig und betreut den Sortimentsbereich
      Fußballtore. Die Ratgeber auf fussballtore.de entstehen unter seiner redaktionellen
      Verantwortung.
    </p>

    <!-- Was du erwarten kannst -->
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mt-12 mb-4">
      Was du von uns erwarten kannst
    </h2>
    <ul class="space-y-3 text-neutral-600 leading-relaxed mb-6">
      <li class="flex items-start gap-3">
        <span class="inline-block w-2 h-2 rounded-full bg-accent mt-2.5 flex-shrink-0"></span>
        <span>Empfehlungen, die wir auch einem Freund geben würden.</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="inline-block w-2 h-2 rounded-full bg-accent mt-2.5 flex-shrink-0"></span>
        <span>Fakten und Normen unabhängig recherchiert (DFB, FIFA, DIN EN 748, DGUV 202-044).</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="inline-block w-2 h-2 rounded-full bg-accent mt-2.5 flex-shrink-0"></span>
        <span>Schwächen eines Produkts nennen wir genauso wie Stärken.</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="inline-block w-2 h-2 rounded-full bg-accent mt-2.5 flex-shrink-0"></span>
        <span>Keine Superlative, keine Werbe-Floskeln. Wir schreiben sachlich.</span>
      </li>
    </ul>

    <!-- Verbindung -->
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mt-12 mb-4">
      Unsere Verbindung zu anstoss24.de
    </h2>
    <p class="text-neutral-600 leading-relaxed mb-4">
      Ehrlich und kurz: fussballtore.de wird vom Vereinsbedarf-Fachhandel
      <a
        href={addUtm('https://www.anstoss24.de/', 'ueber-uns')}
        target="_blank"
        rel="noopener"
        class="text-accent hover:text-accent-dark transition-colors font-medium"
      >anstoss24.de</a>
      betrieben. Unsere Produktempfehlungen führen daher zu anstoss24.de. Wenn du dort
      kaufst, hilft uns das, diesen Ratgeber weiter zu betreiben.
    </p>
    <p class="text-neutral-600 leading-relaxed mb-4">
      Die Empfehlungen treffen wir trotzdem nicht zufällig: Wir empfehlen die Produkte,
      die wir aus unserer täglichen Arbeit kennen — und die wir auch
      privat oder unserem Heimatverein vorschlagen würden.
    </p>

    <!-- KI-Hinweis -->
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mt-12 mb-4">
      So entstehen unsere Ratgeber
    </h2>
    <p class="text-neutral-600 leading-relaxed mb-4">
      Die Inhalte basieren auf 14 Jahren Praxis im Vereinsbedarf-Handel. Für die
      redaktionelle Aufbereitung der Texte setzen wir moderne KI-Tools ein —
      sämtliche Texte werden vor Veröffentlichung redaktionell geprüft und freigegeben.
    </p>

    <!-- Kontakt -->
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mt-12 mb-4">
      Kontakt
    </h2>
    <ul class="space-y-2 text-neutral-600 leading-relaxed mb-6">
      <li><strong>E-Mail:</strong> <a href="mailto:info@anstoss24.de" class="text-accent hover:text-accent-dark transition-colors">info@anstoss24.de</a></li>
      <li><strong>Telefon:</strong> 08435 - 485 9568 (Mo–Fr 7:30–17:30 Uhr)</li>
    </ul>

    <p class="text-sm text-neutral-500 leading-relaxed mt-10 pt-6 border-t border-neutral-200">
      Vollständige Anbieterkennzeichnung im <a href="/impressum/" class="text-accent hover:text-accent-dark transition-colors">Impressum</a>.
    </p>
  </article>
</BaseLayout>
